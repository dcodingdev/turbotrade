{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": ".",
    "paths": {
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/api-contracts": ["../../packages/api-contracts/src/index.ts"],
      "@repo/logger": ["../../packages/logger/src/index.ts"],
      "@repo/database": ["../../packages/database/src/index.ts"],
      "@repo/rabbitmq": ["../../packages/rabbitmq/src/index.ts"],
      "@repo/common": ["../../packages/common/src/index.ts"]
    },

    "outDir": "dist",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "express", "cors", "amqplib"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}