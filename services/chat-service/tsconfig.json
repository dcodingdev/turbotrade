{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": ".",
    "outDir": "dist",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@repo/types": ["../../packages/types/src/user"],
      "@repo/api-contracts": ["../../packages/api-contracts/src/index"],
      "@repo/logger": ["../../packages/logger/src/index"],
      "@repo/database": ["../../packages/database/src/index"],
      "@repo/rabbitmq": ["../../packages/rabbitmq/src/index"],
      "@repo/auth-service": ["../auth-service/index.ts"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}