      "@types/serve-static": "1.15.5"
    }
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^20.11.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.11",
    "typescript": "^5.7.3"
  }
}