{
  "name": "ecommerce",
  "version": "1.0.0",
  "description": "Ecommerce Microservices Monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -- turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
