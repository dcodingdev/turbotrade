{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    // Output settings
    "outDir": "./dist",
    "rootDir": "./src",
    
    // Monorepo & Development Essentials
    "declaration": true,      // Generates .d.ts files for IntelliSense
    "declarationMap": true,   // Maps types back to source for "Go to Definition"
    "sourceMap": true,        // Essential for debugging in Dev
    "composite": true,        // Allows Turborepo to build incrementally
    
    // Strictness
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "../types/src/express.d.ts"],
  "exclude": ["node_modules", "dist"]
}